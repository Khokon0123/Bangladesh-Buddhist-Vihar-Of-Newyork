{
  "name": "buddhist-temple-website",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "ulimit -n 10240 2>/dev/null || true; next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "build:check": "npm run type-check && npm run lint && npm run build",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "@vercel/kv": "^3.0.0",
    "framer-motion": "^12.24.7",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
