# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Admin Authentication ────────────────────────────────────────────────────
# Password for the single admin user (min 12 chars recommended)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret key for signing session cookies (generate with: openssl rand -base64 32)
SESSION_SECRET=generate-a-random-32-plus-char-string-here

# ─── Upstash Redis (via Vercel Marketplace → Upstash → Redis) ────────────────
# Auto-populated by Vercel when you connect an Upstash Redis database.
# Leave blank for local dev — app falls back to static TypeScript data.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Vercel Blob ─────────────────────────────────────────────────────────────
# Auto-populated by Vercel when you link a Blob store.
# Required for image uploads in the admin panel.
BLOB_READ_WRITE_TOKEN=

# CMS Configuration (for future use)
# CMS_API_URL=
# CMS_API_KEY=
# CMS_PREVIEW_SECRET=

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GTM_ID=

# Feature Flags
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_PREVIEW=false

# Environment
NODE_ENV=production
